                    <div className="inline-actions">
                      <button
                        className="secondary-btn"
                        onClick={() => void handleTest(proxy.id)}
                      >
                        Test
                      </button>
                      <button
                        className="danger-btn"
                        onClick={() => void handleDelete(proxy.id)}
