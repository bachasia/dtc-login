        <button
          className={page === 'proxies' ? 'nav-button active' : 'nav-button'}
          onClick={() => onChangePage('proxies')}
        >
          Proxies
        </button>
        <button
          className={page === 'settings' ? 'nav-button active' : 'nav-button'}
