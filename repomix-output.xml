          <h3 className="section-title">Nhóm</h3>
          <button className="ghost-btn" onClick={() => setSelectedGroup(null)}>
            Tất cả
          </button>
        </div>

        <div className="group-list">
          {groups.map((group) => (
            <button
              key={group.id}
              className={
                selectedGroup === group.id
                  ? 'group-button active'
                  : 'group-button'
              }
